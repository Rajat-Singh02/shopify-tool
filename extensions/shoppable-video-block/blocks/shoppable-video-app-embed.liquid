{% liquid
  assign shoppable_app_url = block.settings.app_url | default: 'https://shopify-tool-live-git-main-rajat-sahadev-s-projects.vercel.app'
  assign configured_widget_ids = block.settings.widget_ids | split: ','
%}

{% for raw_widget_id in configured_widget_ids %}
  {% assign widget_id = raw_widget_id | strip %}
  {% if widget_id != blank %}
    <script
      async
      src="{{ shoppable_app_url }}/widget.js"
      data-shop="{{ shop.permanent_domain }}"
      data-widget-id="{{ widget_id | escape }}"
    ></script>
  {% endif %}
{% endfor %}

{% schema %}
{
  "name": "Shoppable video widgets",
  "target": "body",
  "settings": [
    {
      "type": "text",
      "id": "widget_ids",
      "label": "Widget IDs",
      "info": "Paste one or more widget IDs separated by commas."
    },
    {
      "type": "text",
      "id": "app_url",
      "label": "App URL",
      "default": "https://shopify-tool-live-git-main-rajat-sahadev-s-projects.vercel.app"
    }
  ]
}
{% endschema %}
