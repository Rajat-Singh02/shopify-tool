# -----------------------------
# App
# -----------------------------
NODE_ENV=development
APP_ENV=development
APP_URL=https://your-vercel-project.vercel.app
PORT=3000
SESSION_SECRET=replace-with-long-random-string

# -----------------------------
# Shopify
# -----------------------------
SHOPIFY_API_KEY=replace-from-shopify-partner-dashboard
SHOPIFY_API_SECRET=replace-from-shopify-partner-dashboard
SHOPIFY_APP_URL=https://your-vercel-project.vercel.app
SHOPIFY_SCOPES=read_products
SHOPIFY_API_VERSION=2026-04

# Optional but useful in dev
SHOPIFY_STORE_DOMAIN=your-dev-store.myshopify.com

# -----------------------------
# Database
# -----------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoppable_video_dev?schema=public
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shoppable_video_test?schema=public

# -----------------------------
# Storage
# -----------------------------
STORAGE_PROVIDER=local

LOCAL_STORAGE_ROOT=./.data/storage
PUBLIC_MEDIA_BASE_URL=http://localhost:3000/media

# For production S3/R2-compatible storage
S3_ENDPOINT=https://replace-with-s3-or-r2-endpoint
S3_REGION=auto
S3_BUCKET=replace-with-bucket-name
S3_ACCESS_KEY_ID=replace-with-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-secret-access-key
S3_PUBLIC_BASE_URL=https://cdn.example.com

# -----------------------------
# Video processing
# -----------------------------
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
MAX_VIDEO_SIZE_MB=500
ALLOWED_VIDEO_MIME_TYPES=video/mp4,video/quicktime,video/webm

# -----------------------------
# Jobs / worker
# -----------------------------
QUEUE_PROVIDER=memory
REDIS_URL=

# -----------------------------
# Analytics
# -----------------------------
ANALYTICS_ENABLED=true

# -----------------------------
# Security
# -----------------------------
ENCRYPTION_KEY=replace-with-32-byte-base64-key
WEBHOOK_SECRET=usually-same-as-shopify-api-secret-unless-your-code-separates-it

# -----------------------------
# Testing
# -----------------------------
PLAYWRIGHT_BASE_URL=http://localhost:3000
